# ──────────────────────────────────────────────
# MoCampaign — Environment Variables
# Copy this file to .env.local and fill in values
# ──────────────────────────────────────────────

# AWS Configuration
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# DynamoDB Tables
DYNAMODB_USERS_TABLE=mocampaign-users
DYNAMODB_CAMPAIGNS_TABLE=mocampaign-campaigns
DYNAMODB_DONATIONS_TABLE=mocampaign-donations

# S3
S3_BUCKET=mocampaign-assets

# Auth
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
